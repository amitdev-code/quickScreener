# ── Application ───────────────────────────────────────────
APP_ENV=development
APP_NAME=AIScreener
APP_HOST=0.0.0.0
APP_PORT=8000

# ── Database ──────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://aiscreener:aiscreener@localhost:5432/aiscreener
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ── Redis ─────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Platform JWT ──────────────────────────────────────────
JWT_SECRET_KEY=                       # RS256 private key — run scripts/gen-jwt-keys.sh
JWT_PUBLIC_KEY=                       # RS256 public key  — run scripts/gen-jwt-keys.sh
JWT_ALGORITHM=RS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
JWT_INTERVIEW_LINK_EXPIRE_HOURS=72

# ── Password Hashing ──────────────────────────────────────
BCRYPT_ROUNDS=12

# ── MFA ───────────────────────────────────────────────────
MFA_TOTP_SECRET_ENCRYPTION_KEY=       # 32-byte hex: python -c "import secrets; print(secrets.token_hex(32))"
MFA_ISSUER_NAME=AIScreener

# ── Cookie ────────────────────────────────────────────────
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# ── Email ─────────────────────────────────────────────────
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@aiscreener.local

# ── CORS ──────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
