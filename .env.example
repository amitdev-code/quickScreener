# ── Application ───────────────────────────────────────────
APP_ENV=development                   # development | staging | production
APP_NAME=AIScreener
APP_HOST=0.0.0.0
APP_PORT=8000

# ── Database ──────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/aiscreener
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ── Redis ─────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Platform JWT ──────────────────────────────────────────
JWT_SECRET_KEY=                       # RS256 private key (PEM)
JWT_PUBLIC_KEY=                       # RS256 public key (PEM)
JWT_ALGORITHM=RS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
JWT_INTERVIEW_LINK_EXPIRE_HOURS=72

# ── Password Hashing ──────────────────────────────────────
BCRYPT_ROUNDS=12

# ── MFA ───────────────────────────────────────────────────
MFA_TOTP_SECRET_ENCRYPTION_KEY=       # AES-256 key for encrypting TOTP secrets at rest
MFA_ISSUER_NAME=AIScreener

# ── Cookie ────────────────────────────────────────────────
COOKIE_DOMAIN=.aiscreener.com
COOKIE_SECURE=true
COOKIE_SAMESITE=lax

# ── Email (password reset, MFA backup codes) ─────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@aiscreener.com

# ── CORS ──────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
